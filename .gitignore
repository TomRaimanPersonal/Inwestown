## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.suo
*.user
*.csproj.user
*.userosscache
*.sln.docstates
.vscode
commits.txt
Temp.txt
.pre-commit-config.yaml

#Node, playwright and allure
node_modules/
test-results/
playwright-report/
playwright/.cache/
allure-report/
allure-results/
package-lock.json

#Env file
.env

#Storage state files
auth/

# Ignore Mac .DS_Store
.DS_Store

# Idea files
.idea

#NYC coverage report
nyc-result